{
  "name": "@guardiant/cli",
  "version": "0.2.0",
  "description": "Command-line interface for Guardiant security scanner - detect vulnerabilities in AI-generated applications",
  "keywords": [
    "security",
    "cli",
    "vulnerability-scanner",
    "ai-security",
    "vibe-coding",
    "penetration-testing"
  ],
  "author": "Guardiant Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guardiant/guardiant.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/guardiant/guardiant#readme",
  "bugs": {
    "url": "https://github.com/guardiant/guardiant/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "bin": {
    "guardiant": "./dist/index.js",
    "vibeguard": "./dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@guardiant/core": "workspace:*",
    "@guardiant/shared": "workspace:*",
    "@guardiant/database": "workspace:*",
    "@guardiant/queue": "workspace:*",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^9.3.0",
    "cli-table3": "^0.6.5",
    "conf": "^13.0.1",
    "update-notifier": "^7.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.14",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}