# =============================================================================
# Guardiant — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers (at least one required for AI-assisted analysis)
# -----------------------------------------------------------------------------

# Anthropic Claude — primary provider (best security reasoning)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — backup multi-model aggregator
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Google Gemini — secondary backup
# Get your key at: https://aistudio.google.com
GOOGLE_API_KEY=AIza...

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# SQLite database file path
# Defaults to ~/.guardiant/guardiant.db if not set
# DATABASE_PATH=/var/data/guardiant.db

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Maximum number of agents to run in parallel per scan (default: 3)
GUARDIANT_MAX_CONCURRENCY=3

# Per-request HTTP timeout in milliseconds (default: 30000)
GUARDIANT_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Redis Queue (optional — uses in-memory queue if not set)
# Required for production multi-worker deployments
# -----------------------------------------------------------------------------

# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Analytics (optional — PostHog product analytics)
# Get your key at: https://app.posthog.com/project/settings
# -----------------------------------------------------------------------------

# PostHog project API key (enables usage tracking)
# POSTHOG_API_KEY=phc_...

# PostHog instance URL (defaults to cloud if not set)
# POSTHOG_HOST=https://app.posthog.com
