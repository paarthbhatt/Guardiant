{
  "name": "@guardiant/database",
  "version": "0.2.0",
  "description": "SQLite database schema and operations for Guardiant security platform",
  "keywords": [
    "security",
    "database",
    "sqlite",
    "drizzle",
    "orm"
  ],
  "author": "Guardiant Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guardiant/guardiant.git",
    "directory": "packages/database"
  },
  "homepage": "https://github.com/guardiant/guardiant#readme",
  "bugs": {
    "url": "https://github.com/guardiant/guardiant/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrations/run.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@guardiant/shared": "workspace:*",
    "drizzle-orm": "^0.38.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}