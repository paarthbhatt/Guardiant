{
  "name": "@guardiant/shared",
  "version": "0.2.0",
  "description": "Shared types, constants, and utilities for Guardiant security platform",
  "keywords": [
    "security",
    "vulnerability",
    "types",
    "utilities"
  ],
  "author": "Guardiant Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guardiant/guardiant.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/guardiant/guardiant#readme",
  "bugs": {
    "url": "https://github.com/guardiant/guardiant/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "winston": "^3.17.0",
    "uuid": "^11.0.3",
    "zod": "^3.24.1",
    "posthog-node": "^4.2.1"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}