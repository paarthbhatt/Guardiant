{
  "name": "@guardiant/queue",
  "version": "0.2.0",
  "description": "Job queue system for Guardiant security platform with in-memory and BullMQ backends",
  "keywords": [
    "security",
    "queue",
    "bullmq",
    "job",
    "background"
  ],
  "author": "Guardiant Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guardiant/guardiant.git",
    "directory": "packages/queue"
  },
  "homepage": "https://github.com/guardiant/guardiant#readme",
  "bugs": {
    "url": "https://github.com/guardiant/guardiant/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@guardiant/shared": "workspace:*",
    "bullmq": "^5.30.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  }
}