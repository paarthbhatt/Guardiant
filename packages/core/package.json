{
  "name": "@guardiant/core",
  "version": "0.2.0",
  "description": "Core business logic for Guardiant security platform - agents, analyzers, orchestrator, and report generation",
  "keywords": [
    "security",
    "vulnerability",
    "agent",
    "scanner",
    "penetration-testing",
    "ai-security"
  ],
  "author": "Guardiant Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guardiant/guardiant.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/guardiant/guardiant#readme",
  "bugs": {
    "url": "https://github.com/guardiant/guardiant/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    },
    "./analyzers": {
      "types": "./dist/analyzers/index.d.ts",
      "import": "./dist/analyzers/index.js"
    },
    "./orchestrator": {
      "types": "./dist/orchestrator/index.d.ts",
      "import": "./dist/orchestrator/index.js"
    },
    "./cache": {
      "types": "./dist/cache/recon-cache.d.ts",
      "import": "./dist/cache/recon-cache.js"
    },
    "./report/stream": {
      "types": "./dist/report/stream.d.ts",
      "import": "./dist/report/stream.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@guardiant/database": "workspace:*",
    "@guardiant/queue": "workspace:*",
    "@guardiant/shared": "workspace:*",
    "openai": "^4.77.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^2.1.8"
  }
}