{
  "name": "guardiant",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic Security Platform for Vibe-Coded Applications",
  "keywords": [
    "security",
    "vulnerability-scanner",
    "ai-security",
    "vibe-coding",
    "penetration-testing"
  ],
  "author": "Guardiant Team",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "cli": "pnpm --filter @guardiant/cli dev",
    "web": "pnpm --filter @guardiant/web dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.8.17",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}